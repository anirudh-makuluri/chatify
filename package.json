{
  "name": "chatify-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:all": "turbo run dev --parallel",
    "dev:backend": "pnpm --filter @chatify/backend mon",
    "dev:web": "pnpm --filter @chatify/web dev",
    "dev:mobile": "pnpm --filter @chatify/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
